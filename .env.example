# FableCut plan.js — ключі для «мозку». Скопіюй: cp .env.example .env
OPENAI_API_KEY=sk-...          # whisper-1 транскрипція зі словниковими таймкодами (обов'язково)
GOOGLE_API_KEY=...             # Gemini — вибір найцікавіших моментів (aka GEMINI_API_KEY)

# оверрайди моделей (необов'язково):
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o
